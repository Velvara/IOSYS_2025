# This .gitignore file is for a Unity project.
#

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ex]portedObj/
/[Ll]ogs/
/[Vv]ideo/

# Memory dumps
*.log
*.dump

# Crashlytics generated file
crashlytics-build.properties

# Mac OS files
.DS_Store
.AppleDouble
.LSOverride

# Windows thumbnail caches
Thumbs.db
ehthumbs.db

# Visual Studio / Rider / VS Code isolation and cache folders
.vs/
.idea/
.gradle/
.RiderCpp*/
*.sln
*.csproj
*.unityproj
*.suo
*.user
*.userosscache
*.sln.docstates

# Built application files
*.apk
*.aab
*.unitypackage
*.app

# Asset store packages (can be re-downloaded)
/[Aa]ssets/AssetStoreTools*

# WebGL build output
/[Aa]ssets/[Ww]ebGLTemplates/*/[Dd]evelopment/