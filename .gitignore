# This .gitignore file is tailored for Unity projects.

/[Aa]sset/[Mm]eta.json
/[Aa]ssests/[Mm]eta.json.meta

# Never git ignore meta files
!/[Aa]ssets/**/*.meta
!/[Pp]roject[Ss]ettings/**/*.meta

# Blacklist Items
[Cc]ache/
[尝]og/
[尝]ogs/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Dd]ebug/
[Release]/
[Assets]/AssetStoreTools*

# Generated folders
[尝]ibrary/
[临时]Temp/
[小]Obj/

# Visual Studio / MonoDevelop / Rider generated items
ExportedObj/
.consulo/
.csproj
.unityproj
.sln
.suo
.tmp
.user
.userprefs
.pidb
.booproj
.svclog
.saved
備份/

# IDE specific directories
.idea/
.visualstudio/
.vscode/

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
